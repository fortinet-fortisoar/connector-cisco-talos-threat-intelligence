{
  "name": "cisco-talos-threat-intelligence",
  "version": "1.0.0",
  "label": "Cisco Talos Threat Intelligence",
  "description": "Talos Threat Intelligence connector enables seamless integration with Cisco Talos Threat Intelligence using CIsco SecureX APIs to retrieve reputation data for IPs, domains, URLs, and file hashes. This helps security teams automate threat intelligence gathering and enhance incident response workflows.",
  "publisher": "SpryIQ.co",
  "cs_compatible": true,
  "cs_approved": false,
  "contributor": "Roshan Bangera",
  "icon_small_name": "small.png",
  "icon_large_name": "large.png",
  "help_online": "https://github.com/fortinet-fortisoar/connector-talos-threat-intelligence/blob/release/1.0.0/docs/README.md",
  "category": [
    "Threat Intelligence",
    "ThreatIntel"
  ],
  "configuration": {
    "fields": [
      {
        "title": "Server URL",
        "type": "text",
        "name": "server_url",
        "required": true,
        "visible": true,
        "editable": true,
        "placeholder": "https://visibility.amp.cisco.com",
        "tooltip": "Base URL of the Cisco SecureX API.",
        "description": "The full URL to the Cisco SecureX Threat Response server.",
        "value": ""
      },
      {
        "title": "Client ID",
        "type": "text",
        "name": "client_id",
        "required": true,
        "visible": true,
        "editable": true,
        "tooltip": "Client ID issued by Cisco SecureX.",
        "description": "Used for authenticating with the Cisco SecureX Threat Response API."
      },
      {
        "title": "Client Secret",
        "type": "password",
        "name": "client_secret",
        "required": true,
        "visible": true,
        "editable": true,
        "tooltip": "Client Secret associated with the Client ID.",
        "description": "Secret key used in combination with the Client ID to authenticate with the API."
      },
      {
        "title": "Verify SSL",
        "type": "checkbox",
        "name": "verify_ssl",
        "required": false,
        "visible": true,
        "editable": true,
        "tooltip": "Enable to verify SSL certificates.",
        "description": "Set this to true to verify the SSL certificate of the Cisco SecureX server.",
        "value": true
      }
    ]
  },
  "operations": [
    {
