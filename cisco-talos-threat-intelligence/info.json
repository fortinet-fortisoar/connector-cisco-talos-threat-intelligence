          "title": "IP Address",
          "type": "text",
          "name": "ip_address",
          "required": true,
          "visible": true,
          "editable": true,
          "tooltip": "The IP address to retrieve reputation data for.",
          "description": "Specify a valid IP address to check its threat reputation."
        }
